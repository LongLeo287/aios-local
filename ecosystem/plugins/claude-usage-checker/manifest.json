{
	"manifest_version": 3,
	"name": "Claude Usage Checker",
	"version": "1.0.0",
	"description": "Track your Claude.ai usage with a beautiful floating popup.",
	"content_scripts": [
		{
			"matches": [
				"https://claude.ai/*"
			],
			"js": [
				"content.js"
			],
			"css": [
				"tracker-styles.css"
			]
		}
	],
	"permissions": [
		"storage"
	],
	"host_permissions": [
		"*://claude.ai/*"
	],
	"web_accessible_resources": [
		{
			"resources": [
				"tracker-styles.css"
			],
			"matches": [
				"<all_urls>"
			]
		}
	],
	"icons": {
		"128": "icon128.png",
		"512": "icon512.png"
	},
	"action": {
		"default_icon": "icon128.png",
		"default_title": "Claude Usage Checker"
	}
}