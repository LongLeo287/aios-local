# =============================================================
# AI OS — MASTER SECRETS TEMPLATE
# =============================================================
# Sao chép file này thành `.env` và điền giá trị thực.
# TUYỆT ĐỐI KHÔNG commit .env lên git.
# Xem SECRETS_REGISTRY.md để biết thêm về từng key.
#
# Usage:
#   copy .env.master.example ..\.env
#   (rồi mở ..\.env và điền tất cả values)
# =============================================================

# ─── AI / LLM Providers ───────────────────────────────────────
ANTHROPIC_API_KEY=                   # sk-ant-api03-...
OPENAI_API_KEY=                      # sk-...
GOOGLE_AI_API_KEY=                   # AIza...
GROQ_API_KEY=                        # gsk_...
OPENROUTER_API_KEY=                  # sk-or-...
NINE_ROUTER_API_KEY=                 # sk-...

# ─── GitHub ───────────────────────────────────────────────────
GITHUB_TOKEN=                        # github_pat_...

# ─── Database / Supabase ──────────────────────────────────────
SUPABASE_URL=                        # https://<ref>.supabase.co
SUPABASE_ANON_KEY=                   # eyJ...
SUPABASE_SERVICE_ROLE_KEY=           # eyJ... (⚠️ SUPER SECRET — dùng server-side only)
DATABASE_URL=                        # postgresql://...

# ─── Communication / Notifications ────────────────────────────
TELEGRAM_BOT_TOKEN=                  # 8751070516:AABcd...
TELEGRAM_CHAT_ID=                    # Số ID (lấy từ @userinfobot)
SLACK_BOT_TOKEN=                     # xoxb-...
DISCORD_WEBHOOK_URL=                 # https://discord.com/api/webhooks/...

# ─── Cloud / Deployment ───────────────────────────────────────
VERCEL_TOKEN=                        # ...
AWS_ACCESS_KEY_ID=                   # AKIA...
AWS_SECRET_ACCESS_KEY=               # ...
GCP_SERVICE_ACCOUNT_KEY=             # {...} (JSON string)

# ─── App Config (không sensitive) ─────────────────────────────
TZ=Asia/Ho_Chi_Minh
DATA_DIR=/app/data

# ─── Other Services ───────────────────────────────────────────
STRIPE_SECRET_KEY=                   # sk_live_...
SENDGRID_API_KEY=                    # SG....
RESEND_API_KEY=                      # re_...
