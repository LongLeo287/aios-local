# =============================================================
# AI OS — SECRET STORE TEMPLATE
# =============================================================
# This is the TEMPLATE file — safe to commit to git.
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#
# NEVER commit the .env file itself!
# =============================================================

# ─── AI OS Runtime ────────────────────────────────────────────
# Absolute path to AI OS root (contains CLAUDE.md + GEMINI.md)
# Default: auto-detected from __dirname in infra/api/server.js
AOS_ROOT=D:\LongLeo\AI OS CORP\AI OS

# ClawTask API URL (notebook MCP server dependency)
CLAWTASK_URL=http://localhost:7474

# API server port
PORT=7000

# ─── GitHub ───────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:packages
GITHUB_TOKEN=your_github_pat_here

# ─── AI / LLM Providers ───────────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# Groq (fast inference): https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter (multi-provider): https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL / Prisma
DATABASE_URL=postgresql://user:password@host:5432/db?schema=public

# Supabase: https://supabase.com/dashboard/project/your-project/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Cloud / Deployment ───────────────────────────────────────
# Vercel: https://vercel.com/account/tokens
VERCEL_TOKEN=...

# AWS IAM
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Google Cloud (Service Account JSON path)
GCP_SERVICE_ACCOUNT_KEY=./secrets/gcp-service-account.json

# ─── Communication / Notifications ────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEGRAM_BOT_TOKEN=...

# ─── Other Services ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
SENDGRID_API_KEY=SG....
RESEND_API_KEY=re_...
